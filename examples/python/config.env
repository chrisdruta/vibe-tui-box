# Non-secret behavior configuration for the generic harness.

DEV_AGENT_CMD=claude
# Run `vibe agent` inside a persistent tmux session (reattach by rerunning it).
DEV_AGENT_TMUX=1
# Session `vibe attach` opens when called without a name — e.g. a services
# session your project/post-start.sh stands up. Unset -> "main".
#DEV_ATTACH_TMUX_SESSION=services
DEV_BOOTSTRAP_STRICT=1
DEV_AUTO_INSTALL=1
DEV_AUTO_GIT_HOOKS=1
DEV_AUTO_GIT_LFS=1
DEV_ENV_FILE=.env
DEV_REQUIRED_COMMANDS="git gh jq rg uv claude"

# Where `vibe show` (no argument) looks for the newest image — clip captures
# land in /tmp. The glob only filters the search; at render time the real
# format is sniffed from file content, never the extension.
VIBE_PREVIEW_DIR=/tmp
VIBE_PREVIEW_GLOB="*.png *.jpg *.jpeg *.gif *.bmp *.webp *.avif"
# Image review (`vibe review`, prefix+i window) is yazi with project-owned
# config in .vibe/yazi/ — keybindings and verdicts live THERE, not
# here. Uncomment to send all vibe-verdict output to one fixed JSONL file
# instead of review-decisions.jsonl beside the images being reviewed.
#VIBE_REVIEW_DECISIONS=/workspaces/myproject/renders/review-decisions.jsonl
