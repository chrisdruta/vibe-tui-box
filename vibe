#!/usr/bin/env bash
set -euo pipefail

# Host launcher. Normally runs as .vibe/harness/vibe inside a consuming
# project (the seeded .vibe/vibe wrapper and the root-level ./vibe symlink
# exec it), but also works from the host PATH (e.g. symlinked into
# ~/.local/bin). The target project is the nearest ancestor of $PWD with a
# .vibe/compose.yaml; when $PWD is outside any project, it falls back to
# the project this script lives in (two levels up, after resolving
# symlinks). Host may be stock macOS: keep this bash-3.2 compatible.
#
# Engine: docker compose + docker exec, directly — no devcontainer CLI, no
# Node on the host. The container definition is the harness base compose
# file with the project's .vibe/compose.yaml merged on top; lifecycle
# (post-create once per container, post-start per start) is run from here.

# Resolve symlinks with a loop (stock macOS readlink has no -f).
self_path="${BASH_SOURCE[0]}"
while [ -L "$self_path" ]; do
  link_target="$(readlink "$self_path")"
  case "$link_target" in
    /*) self_path="$link_target" ;;
    *)  self_path="$(dirname -- "$self_path")/$link_target" ;;
  esac
done
self_dir="$(cd -- "$(dirname -- "$self_path")" && pwd)"

# shellcheck source=src/scripts/repo-root.sh disable=SC1091
. "$self_dir/src/scripts/repo-root.sh"
repo_root="$(find_repo_root_from_pwd || true)"
if [[ -z "$repo_root" ]]; then
  fallback_root="$(cd -- "$self_dir/../.." && pwd)"
  if [[ -n "$(vibe_dir_name_for_root "$fallback_root")" ]]; then
    repo_root="$fallback_root"
  fi
fi

if [[ -z "$repo_root" ]]; then
  echo "No .vibe/compose.yaml (or legacy .devcontainer/) found above: $PWD" >&2
  echo "Run from inside a project set up with install.sh (or via its .vibe/vibe)." >&2
  exit 1
fi

vibe_dirname="$(vibe_dir_name_for_root "$repo_root")"

# `vibe update` needs only git — dispatch before any docker/layout check so
# it also works from inside the container and on the legacy layout.
if [ "${1:-}" = "update" ]; then
  shift
  VIBE_REPO_ROOT="$repo_root" exec bash "$self_dir/src/scripts/update.sh" "$@"
fi

# Plumbing for host-side tooling (tmux-tui.conf bindings): where the harness
# checkout lives, resolved the same way this launcher resolved itself.
if [ "${1:-}" = "__harness-dir" ]; then
  printf '%s\n' "$self_dir"
  exit 0
fi

if [[ "$vibe_dirname" != ".vibe" ]]; then
  echo "This project is on the retired devcontainer layout ($vibe_dirname/)." >&2
  echo "Migrate it first: see the harness docs/updating.md ->" >&2
  echo "\"Migrating to the compose engine\" (one-time, ~5 minutes)." >&2
  exit 1
fi

command_name="${1:-help}"
if (($#)); then
  shift
fi

case "$command_name" in
  help|-h|--help)
    cat <<'HELP'
Usage: vibe COMMAND [ARGUMENT ...]

Commands:
  up          Build/start the container (compose up; runs lifecycle hooks)
  rebuild     Fresh image + fresh container (picks up compose.yaml/Dockerfile edits)
  build       Build the image only
  config      Print the merged compose config (base + project override)
  status      Show all of this project's service containers (dev + sidecars)
  down        Stop & remove all of this project's service containers — dev and
              any sidecars in .vibe/compose.yaml (named volumes are kept)
  update [TAG]  Move the harness pin to TAG (default: newest release): fetch,
              show changelog delta + diff, checkout, stage — commit & rebuild stay yours
  shell       Open a Bash shell in the container
  attach      Attach/create a tmux session in the container
              (SESSION argument > DEV_ATTACH_TMUX_SESSION > "services")
  agent       Run the configured default agent with explicit .env loading
              (--cold: skip CLAUDE.md/AGENTS.md and .claude customizations;
               -a/--agent CMD: run CMD instead of DEV_AGENT_CMD, e.g. -a codex;
               -s/--session NAME: parallel instance in its own session
               agent-NAME — without it a second `vibe agent` reattaches
               the running one)
  run         Run any command with explicit .env loading (e.g. vibe run grok)
  ps          Agents & services at a glance: state, liveness, age
  doctor      Check the active environment
  bootstrap   Rerun create-time dependency setup
  exec        Run an arbitrary command in the container (no .env loading)
  clip        Save the host clipboard image for the container: /tmp, or DIR in the workspace
  tui         The workspace as a riced host-side tmux — THE front door:
              agent pane over a host dock, tabbed windows, palette on
              prefix+Space (needs tmux >= 3.4 on the host; pinned 3.7b
              build: src/scripts/host/install-tmux.sh)
              (--kill: stop the UI server — all projects' tui sessions,
               container agents unaffected; --fresh: --kill, then relaunch;
               --detach: build/heal this project's session WITHOUT
               attaching — put it on a running tui's sidebar from any
               shell, including a host pane of the tui itself)
  show        Preview an image in the terminal (default: newest vibe clip capture)
              (--diag PATH: report format/renderer/error instead of drawing)
  review [DIR]  Read-only browse/review with yazi (file ops & shell are
              unbound; Enter views through a pager); A approves, R rejects
              (with optional note) to .review-decisions.jsonl beside the images
HELP
    exit 0
    ;;
esac

# Inside the container (a `vibe shell`, or a shell window of `vibe tui`)
# the repo — and this launcher — are bind-mounted, so `./vibe show` is a
# natural thing to type there. The lifecycle commands genuinely need the
# host's docker, but the container-facing commands' implementations live
# right here in the harness checkout: dispatch to them directly instead of
# failing the docker probe.
# VIBE_SKIP_CONTAINER_DISPATCH: development escape hatch — harness
# development happens inside the dogfood container, and verify.sh needs to
# drive the host-only code paths (identity, compose invocation) there under
# a stubbed docker. Not a user surface.
if [ -f /.dockerenv ] && [ -z "${VIBE_SKIP_CONTAINER_DISPATCH:-}" ]; then
  case "$command_name" in
    show)      exec bash "$self_dir/src/scripts/show-image.sh" "$@" ;;
    review)    exec bash "$self_dir/src/scripts/review.sh" "$@" ;;
    agent)     exec bash "$self_dir/src/scripts/agent-entry.sh" agent "$@" ;;
    attach)    exec bash "$self_dir/src/scripts/agent-entry.sh" attach "$@" ;;
    doctor)    exec bash "$self_dir/src/scripts/doctor.sh" "$@" ;;
    ps)        exec bash "$self_dir/src/scripts/ps.sh" "$@" ;;
    bootstrap) exec bash "$self_dir/src/scripts/post-create.sh" "$@" ;;
    run)
      (($#)) || { echo "Usage: vibe run COMMAND [ARGUMENT ...]" >&2; exit 2; }
      exec "$self_dir/src/scripts/env-run.sh" "$@"
      ;;
    exec)
      (($#)) || { echo "Usage: vibe exec COMMAND [ARGUMENT ...]" >&2; exit 2; }
      exec "$@"
      ;;
    shell) exec bash "$@" ;;
    *)
      echo "vibe $command_name needs docker and runs on the host — this is a container shell." >&2
      echo "(container-side commands work from here: show review agent attach run exec doctor ps)" >&2
      exit 1
      ;;
  esac
fi

command -v docker >/dev/null 2>&1 || {
  echo "vibe needs docker on the host (Docker Desktop, or docker in WSL)." >&2
  exit 1
}
if docker compose version >/dev/null 2>&1; then
  compose_bin=(docker compose)
elif command -v docker-compose >/dev/null 2>&1; then
  compose_bin=(docker-compose)
else
  echo "vibe needs docker compose (bundled with Docker Desktop)." >&2
  exit 1
fi

ws_base="$(basename -- "$repo_root")"
workdir="/workspaces/$ws_base"

# Per-checkout project identity (top finding of the 2026-07 external
# review): a basename-only project name collides across same-named
# checkouts, and the collision is the whole compose namespace —
# containers, sidecars, network, image tags — not just the documented
# agent-state volume. The identity is therefore
#   vibe-<sanitized basename>-<8-hex canonical-path digest>
# persisted in .vibe/.project-id on first use (per checkout, never
# committed; git worktrees each get their own). The FILE is the identity:
# moving a checkout keeps its containers; deleting the file regenerates
# the same suffix for an unmoved checkout. Checkouts that already ran
# under the unsuffixed name adopt it instead — probed via compose's own
# project + working_dir labels (docker ANDs repeated label filters, which
# is exactly right here), so another same-named repo's containers can
# never trigger adoption. The agent-state volume name stays derived from
# the bare basename: separate, documented ABI (AGENTS.md).
project_slug="$(vibe_project_slug "$repo_root")"
vibe_dir="$(vibe_dir_name_for_root "$repo_root")"
project_id_file="$repo_root/$vibe_dir/.project-id"
project_name=""
if [ -f "$project_id_file" ]; then
  project_name="$(tr -d '[:space:]' <"$project_id_file")"
  case "$project_name" in
    "" | *[!a-z0-9_-]*) project_name="" ;; # corrupt/foreign content: reseed
  esac
fi
if [ -z "$project_name" ]; then
  legacy_probe_ok=1
  legacy_ids="$(docker ps -aq \
    --filter "label=com.docker.compose.project=$project_slug" \
    --filter "label=com.docker.compose.project.working_dir=$repo_root" \
    2>/dev/null)" || legacy_probe_ok=0
  if [ -n "$legacy_ids" ]; then
    project_name="$project_slug"
  else
    project_name="$project_slug-$(vibe_checkout_suffix "$repo_root")"
  fi
  if [ "$legacy_probe_ok" = 1 ]; then
    # Persist only when the daemon answered — a down daemon could
    # misclassify a pre-suffix checkout as fresh and strand its containers.
    printf '%s\n' "$project_name" >"$project_id_file.tmp" \
      && mv "$project_id_file.tmp" "$project_id_file"
    # Per-checkout and never committed: park the ignore entry in
    # .git/info/exclude (worktree-shared) instead of churning the
    # consumer's .gitignore. Best-effort — a read-only or non-git tree
    # just skips it.
    exclude_file="$(git -C "$repo_root" rev-parse --git-path info/exclude 2>/dev/null || true)"
    if [ -n "$exclude_file" ]; then
      case "$exclude_file" in /*) ;; *) exclude_file="$repo_root/$exclude_file" ;; esac
      if mkdir -p "$(dirname -- "$exclude_file")" 2>/dev/null; then
        grep -qxF "$vibe_dir/.project-id" "$exclude_file" 2>/dev/null \
          || printf '%s\n' "$vibe_dir/.project-id" >>"$exclude_file" 2>/dev/null \
          || true
      fi
    fi
  fi
fi

compose() {
  VIBE_PROJECT_NAME="$project_name" \
  VIBE_WORKSPACE_BASENAME="$ws_base" \
  VIBE_REPO_ROOT="$repo_root" \
  VIBE_USER_UID="$(id -u)" \
  "${compose_bin[@]}" \
    --project-name "$project_name" \
    --project-directory "$repo_root" \
    -f "$self_dir/src/compose/base.yaml" \
    -f "$repo_root/.vibe/compose.yaml" \
    "$@"
}

# The image chain: the build-only `base` service produces the shared
# harness image; a project image extension (.vibe/Dockerfile, declared in
# .vibe/compose.yaml — docs/extending.md) chains a `dev` build on top.
# Sequenced here because `dev` itself may have no build: section, and the
# extension's FROM needs the base tag to exist/refresh first.
build_images() {
  compose --profile build build base
  compose build # no-op unless the project declared an extension build
}

# Any image compose would run missing locally? (dev may not be buildable
# by `up` anymore, so up must know to build first.)
images_missing() {
  local img
  while IFS= read -r img; do
    [ -n "$img" ] || continue
    docker image inspect "$img" >/dev/null 2>&1 || return 0
  done <<EOF
$(compose config --images 2>/dev/null)
EOF
  return 1
}

# Discovery is by label, not container name — resilient to compose naming
# changes. Three labels, three scopes: vibe.project marks the dev container
# (set in base.yaml), the compose-project label covers EVERY service compose
# created for this project (dev + project sidecars — compose stamps it
# itself), and the legacy filter lets status/down see (and clean up) a
# devcontainer-CLI-era container during migration. Never combine two label
# filters in one `docker ps` — docker ANDs repeated label filters, so a
# combined call matches only containers carrying BOTH labels (i.e. nothing).
label_filter="label=vibe.project=$repo_root"
compose_filter="label=com.docker.compose.project=$project_name"
legacy_filter="label=devcontainer.local_folder=$repo_root"

container_id() {
  docker ps -q --filter "$label_filter" | head -n 1
}

# Exec into the container as the workspace user, allocating a pty only when
# we actually have one (keeps `vibe run ... | pipe` clean).
cexec() {
  local cid="$1"
  shift
  local tty_flags="-i"
  if [ -t 0 ] && [ -t 1 ]; then
    tty_flags="-it"
  fi
  # Under `vibe tui` the host tmux session carries VIBE_NESTED=1; forward it
  # so agent-entry.sh knows an outer tmux already draws the chrome. (The
  # ${arr[@]+...} idiom keeps bash 3.2 + set -u happy on an empty array.)
  local env_flags=()
  if [ -n "${VIBE_NESTED:-}" ]; then
    env_flags+=(-e "VIBE_NESTED=$VIBE_NESTED")
  fi
  docker exec "$tty_flags" ${env_flags[@]+"${env_flags[@]}"} -u vscode -w "$workdir" "$cid" "$@"
}

# Bring the container up and run the lifecycle scripts the way the
# devcontainer CLI used to: post-create once per container (marker file on
# the container filesystem — NOT the agent-state volume, so a recreated
# container re-runs it), post-start on every actual (re)start. A `vibe up`
# on an already-running, unchanged container is a fast no-op.
do_up() {
  local pre_cid cid
  pre_cid="$(container_id || true)"
  if images_missing; then
    build_images 1>&2
  fi
  compose up -d "$@" 1>&2
  cid="$(container_id)"
  if [[ -z "$cid" ]]; then
    echo "Container failed to start (docker compose -p $project_name logs)." >&2
    exit 1
  fi
  if [[ "$cid" != "$pre_cid" ]]; then
    if ! docker exec "$cid" test -f /var/tmp/.vibe-post-created 2>/dev/null; then
      cexec "$cid" bash .vibe/harness/src/scripts/post-create.sh 1>&2
      docker exec "$cid" touch /var/tmp/.vibe-post-created
    fi
    cexec "$cid" bash .vibe/harness/src/scripts/post-start.sh 1>&2
  fi
}

# Container commands start the container when it isn't running, so `vibe
# agent` works cold. Progress goes to stderr to keep stdout pipeable.
ensure_up() {
  if [[ -z "$(container_id)" ]]; then
    echo "Container not running for $repo_root — starting it..." >&2
    do_up
  fi
}

case "$command_name" in
  up)
    do_up "$@"
    ;;
  rebuild)
    # Fresh images (base, then extension when declared) + fresh container;
    # cache-honoring, and the agent-state volume is never touched.
    build_images 1>&2
    do_up --force-recreate
    ;;
  build)
    build_images
    ;;
  config)
    # Render the merged compose config — what `up` will actually run.
    # --profile build includes the base image recipe in the render.
    compose --profile build config "$@"
    ;;
  status)
    # All of this project's service containers (dev + sidecars), running or
    # stopped — the compose-project label covers them without needing the
    # compose files to parse. Legacy-era container shown separately.
    docker ps -a --filter "$compose_filter" \
      --format 'table {{.Names}}\t{{.Label "com.docker.compose.service"}}\t{{.Status}}\t{{.Image}}\t{{.Ports}}'
    legacy_ids="$(docker ps -aq --filter "$legacy_filter")"
    if [[ -n "$legacy_ids" ]]; then
      echo
      echo "Legacy devcontainer-era container (vibe down removes it):"
      docker ps -a --filter "$legacy_filter" \
        --format 'table {{.Names}}\t{{.Status}}\t{{.Image}}'
    fi
    exit 0
    ;;
  down)
    # Compose-native teardown: every service container in this project
    # (dev + sidecars declared in .vibe/compose.yaml), the project network,
    # and orphans from since-removed services. Named volumes (agent state,
    # sidecar data) are kept — `vibe up` recreates everything else.
    ids="$(docker ps -aq --filter "$label_filter"; docker ps -aq --filter "$compose_filter")"
    ids="$(printf '%s\n' "$ids" | sort -u | grep . || true)"
    legacy_ids="$(docker ps -aq --filter "$legacy_filter")"
    if [[ -z "$ids" && -z "$legacy_ids" ]]; then
      echo "No containers found for $repo_root" >&2
      exit 0
    fi
    if [[ -n "$ids" ]] && ! compose down --remove-orphans; then
      # Broken/missing compose files (half-migrated repo, syntax error):
      # degrade to label cleanup so down never strands containers.
      echo "compose down failed — removing containers by label instead." >&2
      # shellcheck disable=SC2086  # one id per word is the point
      docker rm -f $ids
      docker network rm "${project_name}_default" >/dev/null 2>&1 || true
    fi
    # Devcontainer-era container predates the compose labels entirely.
    # shellcheck disable=SC2086
    [[ -z "$legacy_ids" ]] || docker rm -f $legacy_ids
    exit 0
    ;;
  attach)
    ensure_up
    cexec "$(container_id)" bash .vibe/harness/src/scripts/agent-entry.sh attach "$@"
    ;;
  shell)
    ensure_up
    cexec "$(container_id)" bash "$@"
    ;;
  agent)
    ensure_up
    # All agent logic (flag parsing, DEV_AGENT_CMD resolution, tmux
    # wrapping) lives container-side in agent-entry.sh, which gets real
    # argv — no payload strings, no re-quoting at this boundary.
    cexec "$(container_id)" bash .vibe/harness/src/scripts/agent-entry.sh agent "$@"
    ;;
  doctor)
    ensure_up
    cexec "$(container_id)" bash .vibe/harness/src/scripts/doctor.sh "$@"
    ;;
  ps)
    ensure_up
    cexec "$(container_id)" bash .vibe/harness/src/scripts/ps.sh "$@"
    ;;
  bootstrap)
    ensure_up
    cexec "$(container_id)" bash .vibe/harness/src/scripts/post-create.sh "$@"
    ;;
  run)
    (($#)) || { echo "Usage: vibe run COMMAND [ARGUMENT ...]" >&2; exit 2; }
    ensure_up
    cexec "$(container_id)" .vibe/harness/src/scripts/env-run.sh "$@"
    ;;
  exec)
    (($#)) || { echo "Usage: vibe exec COMMAND [ARGUMENT ...]" >&2; exit 2; }
    ensure_up
    cexec "$(container_id)" "$@"
    ;;
  show)
    ensure_up
    cexec "$(container_id)" bash .vibe/harness/src/scripts/show-image.sh "$@"
    ;;
  review)
    # yazi in the INVOKING terminal (prefix+i inside the agent session
    # opens the same thing as a dedicated tmux window). A=approve,
    # R=reject-with-note (vibe.yazi plugin); verdicts land in
    # .review-decisions.jsonl beside the images. The project-owned
    # .vibe/yazi/ layers preferences and rebinds on top.
    ensure_up
    cexec "$(container_id)" bash .vibe/harness/src/scripts/review.sh "$@"
    ;;
  clip)
    # Host-side: grabs the OS clipboard image; container /tmp by default,
    # or a workspace-relative DIR (writes straight to the bind mount — no
    # running container needed).
    if [ -n "${1:-}" ]; then
      exec bash "$self_dir/src/scripts/host/clip-image.sh" "$repo_root" "$1" ""
    else
      ensure_up
      exec bash "$self_dir/src/scripts/host/clip-image.sh" "$repo_root" "" "$(container_id)"
    fi
    ;;
  tui | ui)
    # Host-side: the front door. A host TMUX owns layout, tabs, theme,
    # palette — one surface for agent panes AND native host shells (git,
    # vibe clip). Container tmux sessions own persistence underneath.
    # (`vibe open` — WT-native panes — retired 2026-07-21 in its favor;
    # the per-pane commands it composed still work standalone.)
    if [ "$command_name" = "ui" ]; then
      echo "(vibe ui is now: vibe tui)" >&2
    fi
    case "${1:-}" in
      --kill | --fresh)
        # Kill via tui.sh, then reap the ghost viewers the kill just
        # orphaned: docker never kills an exec'd process with its client,
        # so the dead panes' inner tmux clients linger and inflate
        # attached counts. Only when the container is ALREADY running —
        # never boot one to clean a UI (and with no container there are
        # no orphans to reap).
        bash "$self_dir/src/scripts/host/tui.sh" "$repo_root" "$ws_base" "$self_dir" "$project_name" --kill
        cid="$(container_id)" || cid=""
        if [ -n "$cid" ]; then
          cexec "$cid" bash .vibe/harness/src/scripts/agent-entry.sh reap-nested || true
        fi
        if [ "$1" = "--kill" ]; then
          exit 0
        fi
        ensure_up
        exec bash "$self_dir/src/scripts/host/tui.sh" "$repo_root" "$ws_base" "$self_dir" "$project_name"
        ;;
    esac
    ensure_up
    exec bash "$self_dir/src/scripts/host/tui.sh" "$repo_root" "$ws_base" "$self_dir" "$project_name" "$@"
    ;;
  *)
    echo "Unknown command: $command_name" >&2
    exit 2
    ;;
esac
