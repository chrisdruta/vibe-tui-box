{
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/statusline.sh\""
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/subagent-statusline.sh\""
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "sandbox": {
    "enableWeakerNestedSandbox": true,
    "failIfUnavailable": false
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/agent-state-hook.sh\" SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/preview-image-hook.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/agent-state-hook.sh\" UserPromptSubmit"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/preview-image-hook.sh\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/agent-state-hook.sh\" PostToolUse"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/agent-state-hook.sh\" Notification"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/agent-state-hook.sh\" Stop"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/agent-state-hook.sh\" SessionEnd"
          }
        ]
      }
    ]
  }
}
