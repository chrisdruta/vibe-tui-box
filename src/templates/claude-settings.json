{
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/statusline.sh\""
  },
  "subagentStatusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/subagent-statusline.sh\""
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/preview-image-hook.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.vibe/harness/src/scripts/preview-image-hook.sh\""
          }
        ]
      }
    ]
  }
}
