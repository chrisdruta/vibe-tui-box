#!/usr/bin/env bash
#
# vibe host shim — installed to ~/.vibe/bin/vibe and put on the host PATH.
#
# This is the ONLY stable host entry point. It reads no workspace code: it
# resolves the project you are standing in to its trusted, materialized harness
# version and execs THAT version's launcher. A compromised workspace cannot
# change what this runs — the code lives in ~/.vibe/versions/<sha>/, verified
# against a manifest before every exec.
#
# Deliberately dumb and rarely-changing; version-specific logic lives behind it
# in the materialized launcher. Host-side: bash-3.2 (stock macOS) only.
set -euo pipefail

# The store library ships inside every materialized version, but the shim must
# not depend on any particular version to FIND the store. It carries the couple
# of primitives it needs inline (store home, env sanitize, digest, record read,
# manifest verify of the exec paths) so first-contact works before any version
# is trusted. Everything heavier is deferred to the trusted launcher.

# ── inline primitives (kept in lockstep with src/scripts/host/store.sh) ────
sh_die() { printf 'vibe: %s\n' "$1" >&2; exit 1; }

sh_sanitize_env() {
  unset BASH_ENV ENV SHELLOPTS GLOBIGNORE VIBE_TUI_TMUX 2>/dev/null || true
  local v
  for v in $(env 2>/dev/null | sed -n 's/^\(GIT_[A-Za-z0-9_]*\)=.*/\1/p'); do
    unset "$v" 2>/dev/null || true
  done
  GIT_CONFIG_NOSYSTEM=1 GIT_TERMINAL_PROMPT=0
  export GIT_CONFIG_NOSYSTEM GIT_TERMINAL_PROMPT
  # System dirs FIRST (see store.sh vibe_sanitize_env, sol M10) — a workspace
  # dir earlier in PATH must not supply git/sed/stat for the store lookup.
  PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin${PATH:+:$PATH}"; export PATH
}

sh_store_home() {
  if [ -n "${VIBE_HOME:-}" ] && [ "${VIBE_ALLOW_INSECURE_HOME:-}" = "1" ]; then
    printf '%s\n' "$VIBE_HOME"; return 0
  fi
  [ -n "${HOME:-}" ] || sh_die "HOME is unset — cannot locate the trust store"
  printf '%s/.vibe\n' "$HOME"
}

# Minimal store safety before we consume it (sol H6): no symlink components,
# store dir owned by us and not group/world-writable. The trusted launcher does
# the full vibe_path_is_secure walk; this is the shim's own guard.
sh_store_secure() {
  local home="$1" uid owner perm
  case "$home" in /*) ;; *) sh_die "store path is not absolute: $home" ;; esac
  [ -L "$home" ] && sh_die "store dir is a symlink: $home"
  [ -d "$home" ] || return 0   # not created yet (first contact handles bootstrap)
  uid="$(id -u)"
  owner="$(stat -c '%u' "$home" 2>/dev/null || stat -f '%u' "$home" 2>/dev/null || echo -1)"
  [ "$owner" = "$uid" ] || sh_die "store dir $home is not owned by you"
  perm="$(stat -c '%a' "$home" 2>/dev/null || stat -f '%Lp' "$home" 2>/dev/null || echo '')"
  case "$perm" in
    *[2367][0-9] | *[2367]) sh_die "store dir $home is group/world-writable — chmod 700 it" ;;
  esac
}

sh_sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" 2>/dev/null | cut -d' ' -f1
  elif command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" 2>/dev/null | cut -d' ' -f1
  else cksum "$1" 2>/dev/null | cut -d' ' -f1; fi
}
sh_sha256_string() {
  if command -v sha256sum >/dev/null 2>&1; then printf '%s' "$1" | sha256sum | tr -dc '0-9a-f'
  elif command -v shasum >/dev/null 2>&1; then printf '%s' "$1" | shasum -a 256 | tr -dc '0-9a-f'
  else printf '%s' "$1" | cksum | tr -dc '0-9a-f'; fi
}
sh_digest() {
  local c; c="$(cd -- "$1" 2>/dev/null && pwd -P)" || return 1
  sh_sha256_string "$c" | cut -c1-16
}

# nearest ancestor of $PWD that is a harness project (has .vibe/compose.yaml or
# the legacy .devcontainer/devcontainer.json). Pure path test — no code run.
sh_repo_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.vibe/compose.yaml" ] || [ -f "$dir/.devcontainer/devcontainer.json" ]; then
      printf '%s\n' "$dir"; return 0
    fi
    dir="$(dirname -- "$dir")"
  done
  return 1
}

sh_record_get() {
  local file="$1" key="$2" line
  [ -f "$file" ] || return 1
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in "$key="*) printf '%s\n' "${line#*=}"; return 0 ;; esac
  done <"$file"
  return 1
}

# Verify a version dir against its manifest before handing control to it. FULL
# verification (every file, and no extra/removed files) — the launcher sources
# store.sh and later runs other host scripts, so a hand-picked subset is not
# enough (sol H7). Rejects symlinks/special files too.
sh_verify_exec() {
  local dest="$1" home sha manifest line hash mode rel f count=0 want
  home="$(sh_store_home)"; sha="$(basename -- "$dest")"
  manifest="$home/versions/$sha.manifest"
  [ -f "$manifest" ] || return 1
  [ -d "$dest" ] || return 1
  # Any symlink/special file in the tree is an immediate fail.
  if find "$dest" -type l 2>/dev/null | grep -q . || \
     find "$dest" ! -type f ! -type d 2>/dev/null | grep -q .; then
    return 1
  fi
  # Every manifest entry must match (hash + mode).
  while IFS=' ' read -r hash mode rel; do
    [ -n "$rel" ] || continue
    f="$dest/$rel"
    [ -f "$f" ] && [ ! -L "$f" ] || return 1
    want="$(sh_sha256_file "$f")"
    [ "$want" = "$hash" ] || return 1
    count=$((count + 1))
  done <"$manifest"
  # And there must be no EXTRA files beyond the manifest.
  local actual
  actual="$(find "$dest" -type f 2>/dev/null | wc -l | tr -d ' ')"
  [ "$actual" = "$count" ] || return 1
  return 0
}

# Newest materialized version dir name (hex-named, so a plain listing is safe).
sh_newest_version() {
  local home; home="$(sh_store_home)"
  # shellcheck disable=SC2010  # version dirs are hex shas: no odd filenames
  ls -1t "$home/versions" 2>/dev/null | grep -E '^[0-9a-f]+$' | head -1
}

# ── main ───────────────────────────────────────────────────────────────────
sh_sanitize_env

home="$(sh_store_home)"
sh_store_secure "$home"
[ -d "$home" ] || sh_die "no trust store at $home — run the installer's self-step (.vibe/harness/install.sh --self from a checkout you trust)"

root="$(sh_repo_root || true)"

# Outside any project: fall back to the newest installed version so `vibe`,
# `vibe self-update`, `vibe --help` still work from anywhere.
if [ -z "$root" ]; then
  newest="$(sh_newest_version)"
  [ -n "$newest" ] || sh_die "no installed harness version and not inside a project"
  dest="$home/versions/$newest"
  sh_verify_exec "$dest" || sh_die "installed version $newest fails verification (tampered store?)"
  exec bash "$dest/vibe" "$@"
fi

digest="$(sh_digest "$root")" || sh_die "could not resolve project path"
record="$home/state/projects/$digest"

if [ -f "$record" ]; then
  mode="$(sh_record_get "$record" mode 2>/dev/null || echo normal)"
  if [ "$mode" = "dev" ]; then
    # Dev mode still runs a materialized snapshot, never the live bind.
    devver="$(sh_record_get "$record" dev_version 2>/dev/null || true)"
    [ -n "$devver" ] || sh_die "dev-mode record has no dev_version — run: vibe dev sync"
    dest="$home/versions/$devver"
    [ -d "$dest" ] || sh_die "dev snapshot $devver missing — run: vibe dev sync"
    sh_verify_exec "$dest" || sh_die "dev snapshot fails verification — run: vibe dev sync"
    printf '\033[33mvibe: dev mode — running snapshot %s (vibe dev sync to refresh)\033[0m\n' "$(printf '%s' "$devver" | cut -c1-8)" >&2
    VIBE_DEV_MODE=1 export VIBE_DEV_MODE
    exec bash "$dest/vibe" "$@"
  fi
  sha="$(sh_record_get "$record" sha 2>/dev/null || true)"
  case "$sha" in *[!0-9a-f]* | "") sh_die "trust record for this project is corrupt: $record" ;; esac
  dest="$home/versions/$sha"
  if [ ! -d "$dest" ] || ! sh_verify_exec "$dest"; then
    # Trusted SHA not materialized (or tampered) — the launcher's provisioning
    # path re-materializes it. Reach it via the newest installed version.
    newest="$(sh_newest_version)"
    [ -n "$newest" ] || sh_die "trusted version $sha is not materialized and no version is installed"
    ndest="$home/versions/$newest"
    sh_verify_exec "$ndest" || sh_die "store appears tampered"
    exec bash "$ndest/vibe" "$@"
  fi
  exec bash "$dest/vibe" "$@"
fi

# No record for this project: first contact. Run the trust flow from the newest
# installed version (which owns the interactive prompt + materialize + record).
newest="$(sh_newest_version)"
[ -n "$newest" ] || sh_die "no installed harness version — run: .vibe/harness/install.sh --self"
dest="$home/versions/$newest"
sh_verify_exec "$dest" || sh_die "installed version $newest fails verification (tampered store?)"
exec bash "$dest/vibe" "$@"
